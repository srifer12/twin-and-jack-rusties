void DoAntiRecoil(DWORD64 localPlayer) {
    if (!(GetAsyncKeyState(g_recoilKey) & 0x8000)) {
        for (auto& kv : g_recoilDB) kv.second.Reset();
        return;
    }
    std::string weapon = GetCurrentWeaponName(localPlayer);
    if (g_recoilDB.find(weapon) == g_recoilDB.end()) weapon = "default";
    RecoilStep comp = g_recoilDB[weapon].GetCompensation(RECOIL_STRENGTH, RECOIL_RANDOM);
    if (comp.x != 0 || comp.y != 0) {
        mouse_event(MOUSEEVENTF_MOVE, (int)comp.x, (int)comp.y, 0, 0);
    }
}

