// ================================
//  MEMORY HANDLER (direct ReadProcessMemory)
// ================================
HANDLE g_hProcess = NULL;
DWORD64 g_baseAddress = 0;

bool InitMemory() {
    HWND hWnd = FindWindowA(NULL, "Rust");
    if (!hWnd) {
        // also try "RustClient" for some cracked versions
        hWnd = FindWindowA(NULL, "RustClient");
        if (!hWnd) return false;
    }
    DWORD pid; GetWindowThreadProcessId(hWnd, &pid);
    g_hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, pid);
    if (!g_hProcess) return false;
    // get base address of the main module
    HANDLE snap = CreateToolhelp32Snapshot(TH32CS_SNAPMODULE | TH32CS_SNAPMODULE32, pid);
    MODULEENTRY32 me = { sizeof(me) };
    if (Module32First(snap, &me)) {
        do {
            if (_stricmp(me.szModule, "RustClient.exe") == 0 || _stricmp(me.szModule, "Rust.exe") == 0) {
                g_baseAddress = (DWORD64)me.modBaseAddr;
                break;
            }
        } while (Module32Next(snap, &me));
    }
    CloseHandle(snap);
    return g_baseAddress != 0;
}

template<typename T>
T Read(DWORD64 addr) {
    T buffer{};
    SIZE_T read = 0;
    ReadProcessMemory(g_hProcess, (LPCVOID)addr, &buffer, sizeof(T), &read);
    return buffer;
}

