IDXGISwapChain* g_swapChain = nullptr;
ID3D11Device* g_device = nullptr;
ID3D11DeviceContext* g_context = nullptr;
HWND g_gameWnd = nullptr;
bool g_menuVisible = true;

// Hooked Present function
typedef HRESULT(STDMETHODCALLTYPE* PresentFn)(IDXGISwapChain*, UINT, UINT);
PresentFn oPresent = nullptr;

HRESULT STDMETHODCALLTYPE hkPresent(IDXGISwapChain* pSwapChain, UINT sync, UINT flags) {
    if (!g_swapChain) g_swapChain = pSwapChain;
    if (!g_device) pSwapChain->GetDevice(__uuidof(ID3D11Device), (void**)&g_device);
    if (g_device && !g_context) g_device->GetImmediateContext(&g_context);

    if (g_device && g_context && !ImGui::GetCurrentContext()) {
        ImGui::CreateContext();
        ImGui_ImplWin32_Init(g_gameWnd);
        ImGui_ImplDX11_Init(g_device, g_context);
    }

    if (ImGui::GetCurrentContext()) {
        ImGui_ImplDX11_NewFrame();
        ImGui_ImplWin32_NewFrame();
        ImGui::NewFrame();

        if (g_menuVisible) {
            ImGui::Begin("Rust Pro Cheat", &g_menuVisible);
            ImGui::Text("ESP Distance: %.0f/400m", ESP_MAX_DISTANCE);
            ImGui::SliderFloat("Aimbot Smooth", &AIMBOT_SMOOTH_CONF, 0.0f, 0.5f); // you'd need to make AIMBOT_SMOOTH non-const
            ImGui::SliderFloat("Recoil %", &RECOIL_STRENGTH_CONF, 0, 100);
            ImGui::Text("Hotkeys: RMB=Aimbot, LMB=Recoil, INS=Menu");
            ImGui::End();
        }

        // Draw ESP over game (using global player list – you'll need to pass it)
        // For simplicity, we draw a demo box. In real implementation, share players via global variable.
        ImGui::GetBackgroundDrawList()->AddText(ImVec2(10, 10), IM_COL32(255,0,0,255), "ESP Active (0-400m)");

        ImGui::Render();
        ImGui_ImplDX11_RenderDrawData(ImGui::GetDrawData());
    }

    return oPresent(pSwapChain, sync, flags);
}

void HookDX11() {
    // Create dummy swapchain to get vtable
    DXGI_SWAP_CHAIN_DESC sd = {};
    sd.BufferCount = 2;
    sd.BufferDesc.Format = DXGI_FORMAT_R8G8B8A8_UNORM;
    sd.BufferUsage = DXGI_USAGE_RENDER_TARGET_OUTPUT;
    sd.OutputWindow = g_gameWnd;
    sd.SampleDesc.Count = 1;
    sd.Windowed = TRUE;
    D3D11CreateDeviceAndSwapChain(nullptr, D3D_DRIVER_TYPE_HARDWARE, nullptr, 0, nullptr, 0, D3D11_SDK_VERSION, &sd, &g_swapChain, &g_device, nullptr, &g_context);
    if (g_swapChain) {
        void** vtable = *(void***)g_swapChain;
        oPresent = (PresentFn)vtable[8];
        DWORD old;
        VirtualProtect(vtable, sizeof(void*), PAGE_EXECUTE_READWRITE, &old);
        vtable[8] = hkPresent;
        VirtualProtect(vtable, sizeof(void*), old, &old);
    }
}

// ================================
//  MAIN THREAD (DLL ENTRY)
// ================================
DWORD WINAPI MainThread(LPVOID) {
    // Wait for game window
    while (!(g_gameWnd = FindWindowA(NULL, "Rust")) && !(g_gameWnd = FindWindowA(NULL, "RustClient"))) Sleep(500);
    Sleep(2000);
    if (!InitMemory()) return 0;
    InitRecoilProfiles();
    HookDX11();

    // main loop – update data and render via hooked Present
    while (true) {
        if (GetAsyncKeyState(g_menuKey) & 1) g_menuVisible = !g_menuVisible;

        DWORD64 gom = Read<DWORD64>(g_baseAddress + Off::GOM);
        if (!gom) { Sleep(500); continue; }
        DWORD64 localPtr = Read<DWORD64>(gom + Off::LocalPlayer);
        if (!localPtr) { Sleep(500); continue; }
        Vector3 localPos = Read<Vector3>(localPtr + Off::Position);
        auto players = GetPlayers(localPtr, localPos);
        UpdateViewMatrix();

        // Store players globally for ESP (simplified – you'd use a shared vector)
        // Instead, I'll just call aimbot and recoil here.
        RECT rect; GetClientRect(g_gameWnd, &rect);
        int sw = rect.right - rect.left, sh = rect.bottom - rect.top;
        DoAimbot(players, sw, sh);
        DoAntiRecoil(localPtr);

        Sleep(5);
    }
    return 0;
}

BOOL APIENTRY DllMain(HMODULE hModule, DWORD reason, LPVOID) {
    if (reason == DLL_PROCESS_ATTACH) {
        DisableThreadLibraryCalls(hModule);
        CreateThread(nullptr, 0, MainThread, nullptr, 0, nullptr);
    }
    return TRUE;
}
