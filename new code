namespace Off {
    DWORD64 GOM = 0x02B8F4A0;                 // Game Object Manager
    DWORD64 LocalPlayer = 0xB8;               // offset from GOM
    DWORD64 Position = 0x90;                  // Vector3
    DWORD64 Health = 0x430;                   // float
    DWORD64 MaxHealth = 0x434;                // float
    DWORD64 Name = 0x600;                     // wchar_t[32]
    DWORD64 Team = 0x560;                     // int
    DWORD64 SleepingFlag = 0x38;              // byte
    DWORD64 Model = 0x38;                     // pointer
    DWORD64 BoneTransforms = 0x28;            // inside model
    DWORD64 Velocity = 0x1C0;                 // Vector3
    DWORD64 ViewMatrix = 0x03C5A8B0;          // 4x4 matrix (64 bytes)
    DWORD64 ActiveWeapon = 0x578;             // current weapon entity
    DWORD64 WeaponRecoilOffset = 0xE8;        // where recoil displacement sits
}

// ================================
//  WORLD TO SCREEN
// ================================
float g_viewMatrix[16];
void UpdateViewMatrix() {
    DWORD64 vmAddr = g_baseAddress + Off::ViewMatrix;
    for (int i = 0; i < 16; i++)
        g_viewMatrix[i] = Read<float>(vmAddr + i * 4);
}

bool WorldToScreen(Vector3 world, int& sx, int& sy, int sw, int sh) {
    float w = g_viewMatrix[12] * world.x + g_viewMatrix[13] * world.y + g_viewMatrix[14] * world.z + g_viewMatrix[15];
    if (w < 0.01f) return false;
    float inv = 1.0f / w;
    float x = (g_viewMatrix[0] * world.x + g_viewMatrix[1] * world.y + g_viewMatrix[2] * world.z + g_viewMatrix[3]) * inv;
    float y = (g_viewMatrix[4] * world.x + g_viewMatrix[5] * world.y + g_viewMatrix[6] * world.z + g_viewMatrix[7]) * inv;
    sx = (int)((x + 1.0f) * 0.5f * sw);
    sy = (int)((1.0f - (y + 1.0f) * 0.5f) * sh);
    return true;
}

// ================================
//  GET PLAYERS (0-400m, with bones & velocity)
// ================================
Vector3 GetBonePos(DWORD64 playerPtr, int boneId) {
    DWORD64 model = Read<DWORD64>(playerPtr + Off::Model);
    if (!model) return { 0,0,0 };
    DWORD64 bones = Read<DWORD64>(model + Off::BoneTransforms);
    if (!bones) return { 0,0,0 };
    Vector3 pos;
    pos.x = Read<float>(bones + (boneId * 48) + 0x10);
    pos.y = Read<float>(bones + (boneId * 48) + 0x14);
    pos.z = Read<float>(bones + (boneId * 48) + 0x18);
    return pos;
}

std::vector<Player> GetPlayers(DWORD64 localPtr, Vector3 localPos) {
    std::vector<Player> players;
    DWORD64 gom = Read<DWORD64>(g_baseAddress + Off::GOM);
    if (!gom) return players;
    DWORD64 entityList = Read<DWORD64>(gom + 0x20);
    int entityCount = Read<int>(gom + 0x28);
    for (int i = 0; i < min(entityCount, 2048); i++) {
        DWORD64 ent = Read<DWORD64>(entityList + i * 8);
        if (!ent || ent == localPtr) continue;
        Player p;
        p.ptr = ent;
        p.pos = Read<Vector3>(ent + Off::Position);
        p.health = Read<float>(ent + Off::Health);
        p.maxHealth = Read<float>(ent + Off::MaxHealth);
        p.team = Read<int>(ent + Off::Team);
        p.sleeping = (Read<BYTE>(ent + Off::SleepingFlag) & 1) != 0;
        p.alive = (p.health > 0 && !p.sleeping);
        p.distance = sqrtf(pow(p.pos.x - localPos.x, 2) + pow(p.pos.y - localPos.y, 2) + pow(p.pos.z - localPos.z, 2));
        if (!p.alive || p.distance > ESP_MAX_DISTANCE) continue;
        // read name
        wchar_t wname[32];
        for (int j = 0; j < 32; j++) wname[j] = Read<wchar_t>(ent + Off::Name + j * 2);
        wcstombs(p.name, wname, 32);
        // head bone
        p.headPos = GetBonePos(ent, AIMBOT_BONE);
        if (p.headPos.x == 0 && p.headPos.y == 0 && p.headPos.z == 0) {
            p.headPos = p.pos;
            p.headPos.y += 1.75f;
        }
        p.velocity = Read<Vector3>(ent + Off::Velocity);
        players.push_back(p);
    }
    return players;
}

// ================================
//  AIMBOT (WITH PREDICTION)
// ================================
Vector3 PredictPosition(Vector3 currentPos, Vector3 velocity, float distance, float bulletSpeed = 300.0f) {
    if (!AIMBOT_PREDICT) return currentPos;
    float time = distance / bulletSpeed;
    Vector3 pred;
    pred.x = currentPos.x + velocity.x * time * AIMBOT_PREDICT_FACTOR;
    pred.y = currentPos.y + velocity.y * time * AIMBOT_PREDICT_FACTOR;
    pred.z = currentPos.z + velocity.z * time * AIMBOT_PREDICT_FACTOR;
    return pred;
}

void DoAimbot(const std::vector<Player>& players, int screenW, int screenH) {
    if (!(GetAsyncKeyState(g_aimbotKey) & 0x8000)) return;
    // find closest to crosshair
    Player best;
    float bestDist = AIMBOT_FOV_PX;
    int cx = screenW / 2, cy = screenH / 2;
    for (const auto& p : players) {
        int sx, sy;
        if (WorldToScreen(p.headPos, sx, sy, screenW, screenH)) {
            float dx = sx - cx, dy = sy - cy;
            float dist = sqrt(dx*dx + dy*dy);
            if (dist < bestDist) {
                bestDist = dist;
                best = p;
            }
        }
    }
    if (best.ptr == 0) return;

    Vector3 target = PredictPosition(best.headPos, best.velocity, best.distance);
    int tx, ty;
    if (WorldToScreen(target, tx, ty, screenW, screenH)) {
        int deltaX = tx - cx;
        int deltaY = ty - cy;
        // apply smoothing
        deltaX = (int)(deltaX * AIMBOT_SMOOTH);
        deltaY = (int)(deltaY * AIMBOT_SMOOTH);
        mouse_event(MOUSEEVENTF_MOVE, deltaX, deltaY, 0, 0);
    }
}

// ================================
//  ANTI-RECOIL – PER WEAPON PROFILES
// ================================
struct RecoilStep { float x, y; };
struct WeaponProfile {
    std::vector<RecoilStep> steps;
    int currentStep = 0;
    void Reset() { currentStep = 0; }
    RecoilStep GetCompensation(float strength, float randomness) {
        if (currentStep >= steps.size()) return {0,0};
        RecoilStep step = steps[currentStep];
        currentStep++;
        float mult = strength / 100.0f;
        float randX = 1.0f + ((float)(rand() % 1000) - 500) / 1000.0f * (randomness / 100.0f);
        float randY = 1.0f + ((float)(rand() % 1000) - 500) / 1000.0f * (randomness / 100.0f);
        return { -step.x * mult * randX, -step.y * mult * randY };
    }
};

