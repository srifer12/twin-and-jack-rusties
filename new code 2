#include "esp.h"
#include "memory.h"
#include "offsets.h"
#include "ui.h"
#include <imgui.h>

std::vector<Entity> ESP::GetEntitiesInRange(Vector3 localPos, float maxRange) {
    std::vector<Entity> result;
    uintptr_t entityList = Memory::ReadChain(Off::EntityListChain);
    int count = Memory::Read<int>(entityList + Off::EntityCount);
    for (int i = 0; i < count; i++) {
        uintptr_t ent = Memory::Read<uintptr_t>(entityList + i * 8);
        if (!ent) continue;
        Entity e;
        e.ptr = ent;
        e.pos = Memory::Read<Vector3>(ent + Off::Position);
        e.distance = localPos.Distance(e.pos);
        if (e.distance > maxRange) continue;
        e.health = Memory::Read<float>(ent + Off::Health);
        e.name = ReadName(ent);
        e.activeWeapon = ReadWeaponName(ent);
        e.hotbarItems = ReadHotbar(ent);
        e.inventoryValuables = ReadInventoryPreview(ent);
        e.isFriend = UI::IsFriend(e.name);
        result.push_back(e);
    }
    return result;
}

void ESP::DrawEntity(const Entity& e, ImDrawList* draw, int screenW, int screenH) {
    Vector3 feet = e.pos, head = e.pos; head.y += 1.75f;
    int fx, fy, hx, hy;
    if (!WorldToScreen(feet, fx, fy) || !WorldToScreen(head, hx, hy)) return;
    
    float height = fy - hy;
    float width = height * 0.6f;
    int left = hx - width/2;
    
    ImU32 color = e.isFriend ? IM_COL32(0,255,0,255) : IM_COL32(255,0,0,255);
    draw->AddRect(ImVec2(left, hy), ImVec2(left+width, fy), color, 2.0f);
    draw->AddText(ImVec2(left, hy-15), IM_COL32(255,255,255,255), e.name.c_str());
    char dist[32]; sprintf_s(dist, "%.0fm", e.distance);
    draw->AddText(ImVec2(left+width+5, hy+height/2), IM_COL32(255,255,255,255), dist);
    // Health bar, weapon, hotbar, inventory preview, etc.
}
