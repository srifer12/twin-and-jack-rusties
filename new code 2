#include "ui.h"
#include <cmath>
#include <random>

static int g_bone = 48; // head
static float g_smooth = 50.0f;
static float g_rcs = 85.0f;

static Vector3 CubicBezier(Vector3 start, Vector3 end, float t) {
    float t2 = t * t, t3 = t2 * t;
    return start + (end - start) * (3 * t2 - 2 * t3);
}

void Aimbot::Run(uintptr_t localPlayer, const std::vector<Entity>& entities) {
    Entity target = SelectTarget(entities, UI::GetTargetPriority());
    if (!target.ptr) return;
    
    Vector3 targetHead = GetBonePos(target.ptr, g_bone);
    if (!IsVisible(localPlayer, target.ptr)) return; // ray trace
    
    Vector3 localAngles = GetViewAngles(localPlayer);
    Vector3 needed = CalcAngles(localPlayer, targetHead);
    Vector3 delta = needed - localAngles;
    
    // Smoothing: 0 = instant, 100 = cubic bezier with jitter
    float factor = 1.0f - (g_smooth / 100.0f);
    if (g_smooth > 90.0f) {
        // Humanized: random delay + over‑correction
        static std::mt19937 rng(std::chrono::steady_clock::now().time_since_epoch().count());
        std::uniform_real_distribution<float> jitter(-0.5f, 0.5f);
        delta.x += jitter(rng);
        delta.y += jitter(rng);
        float t = (100.0f - g_smooth) / 100.0f;
        Vector3 newAngles = CubicBezier(localAngles, needed, t);
        SetViewAngles(localPlayer, newAngles);
        Sleep(std::uniform_int_distribution<int>(10, 30)(rng));
    } else {
        Vector3 newAngles = localAngles + delta * factor;
        SetViewAngles(localPlayer, newAngles);
    }
    
    // RCS
    if (g_rcs > 0.0f && IsShooting(localPlayer)) {
        Vector2 punch = GetRecoilPunch(localPlayer);
        Vector2 correction = {-punch.x * (g_rcs/100.0f), -punch.y * (g_rcs/100.0f)};
        ApplyMouseMovement((int)correction.x, (int)correction.y);
    }
}
