DWORD WINAPI GameThread(LPVOID) {
    // Wait for game window and D3D11 device
    while (!(g_hwnd = FindWindowA(NULL, "Rust")) && !(g_hwnd = FindWindowA(NULL, "RustClient"))) Sleep(100);
    
    // Hook DX11 Present (using VMT hooking – standard method)
    if (!UI::HookPresent()) {
        MessageBoxA(g_hwnd, "Failed to hook Present", "Error", MB_OK);
        return 0;
    }
    
    // ImGui init inside hooked Present
    while (true) Sleep(1000);
    return 0;
}

DWORD WINAPI LogicThread(LPVOID) {
    // Resolve offsets once at startup
    OffsetResolver::Initialize();
    
    while (g_running) {
        uintptr_t localPlayer = Memory::ReadChain(Off::LocalPlayerChain);
        if (!localPlayer) { Sleep(200); continue; }
        
        Vector3 localPos = Memory::Read<Vector3>(localPlayer + Off::Position);
        auto entities = ESP::GetEntitiesInRange(localPos, UI::GetEspRange());
        
        if (UI::IsAimbotActive() && UI::IsAimbotKeyHeld()) {
            Aimbot::Run(localPlayer, entities);
        }
        
        if (UI::IsAimAssistActive() && UI::IsAimAssistKeyHeld()) {
            AimAssist::Run(localPlayer, entities);
        }
        
        UI::UpdateEntities(entities);
        Memory::RandomSleep(1, 5);  // anti‑pattern
    }
    return 0;
}

BOOL APIENTRY DllMain(HMODULE hModule, DWORD reason, LPVOID) {
    if (reason == DLL_PROCESS_ATTACH) {
        DisableThreadLibraryCalls(hModule);
        // Hide DLL from PEB
        Bypass::UnlinkFromPEB(hModule);
        
        // Spawn threads
        hGameThread = CreateThread(nullptr, 0, GameThread, nullptr, 0, nullptr);
        hLogicThread = CreateThread(nullptr, 0, LogicThread, nullptr, 0, nullptr);
    }
    return TRUE;
}
