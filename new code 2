static NTSTATUS (NTAPI *NtReadVirtualMemory)(HANDLE, PVOID, PVOID, SIZE_T, PSIZE_T) = nullptr;
static NTSTATUS (NTAPI *NtWriteVirtualMemory)(HANDLE, PVOID, PVOID, SIZE_T, PSIZE_T) = nullptr;

void Memory::InitSyscalls() {
    HMODULE ntdll = GetModuleHandleA("ntdll.dll");
    NtReadVirtualMemory = (decltype(NtReadVirtualMemory))GetProcAddress(ntdll, "NtReadVirtualMemory");
    NtWriteVirtualMemory = (decltype(NtWriteVirtualMemory))GetProcAddress(ntdll, "NtWriteVirtualMemory");
}

template<typename T>
T Memory::Read(uintptr_t addr) {
    T buffer{};
    NtReadVirtualMemory(GetCurrentProcess(), (PVOID)addr, &buffer, sizeof(T), nullptr);
    RandomSleep(1, 5);
    return buffer;
}

