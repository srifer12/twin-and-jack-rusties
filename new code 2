#include "aimassist.h"
#include "ui.h"
#include "memory.h"

void AimAssist::Run(uintptr_t localPlayer, const std::vector<Entity>& entities) {
    if (!IsADS(localPlayer) && !UI::IsAimAssistForceKeyHeld()) return;
    
    float radius = UI::GetAimAssistRadius();
    float strength = UI::GetAimAssistStrength() / 100.0f;
    Entity closest = GetClosestToCrosshair(entities, radius);
    if (!closest.ptr) return;
    
    Vector3 targetScreen = WorldToScreen(closest.headPos);
    Vector3 crosshairCenter = { UI::GetScreenWidth() / 2, UI::GetScreenHeight() / 2 };
    Vector3 force = targetScreen - crosshairCenter;
    float mag = sqrt(force.x*force.x + force.y*force.y);
    if (mag < 1.0f) return;
    
    // Dynamic acceleration: stronger when closer
    float pull = strength * (1.0f - (mag / radius));
    force.x *= pull;
    force.y *= pull;
    
    // Apply via SendInput (relative move)
    INPUT input = {0};
    input.type = INPUT_MOUSE;
    input.mi.dwFlags = MOUSEEVENTF_MOVE;
    input.mi.dx = (int)force.x;
    input.mi.dy = (int)force.y;
    SendInput(1, &input, sizeof(INPUT));
}
